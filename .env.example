# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://gem-openai-mm-we-001.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment names
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=code_docs

# Ingestion Configuration
MAX_FILE_SIZE_MB=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Logging
LOG_LEVEL=INFO

# Microservice — Streamlit connects to FastAPI at this base URL
# Local development: http://localhost:8000
# Inside Docker (all-in-one container): http://localhost:8000  (same default)
API_BASE_URL=http://localhost:8000
